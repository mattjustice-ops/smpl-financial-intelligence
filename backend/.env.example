# Copy this file to .env in the same folder (backend/.env) and adjust if needed.
# Default values match docker-compose.yml in the repo root.

DATABASE_URL=postgresql+psycopg://sfi:sfi_dev_password@localhost:5432/sfi

# Comma-separated list of browser origins allowed to call the API (CORS).
# Next.js may use 3000–3010 when ports are busy; include your dev port.
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://127.0.0.1:3002,http://localhost:3003,http://127.0.0.1:3003,http://localhost:3004,http://127.0.0.1:3004,http://localhost:3005,http://127.0.0.1:3005,http://localhost:3006,http://127.0.0.1:3006,http://localhost:3007,http://127.0.0.1:3007,http://localhost:3008,http://127.0.0.1:3008,http://localhost:3009,http://127.0.0.1:3009,http://localhost:3010,http://127.0.0.1:3010

# Optional — shared secret for Next.js billing webhook → FastAPI (must match frontend)
# BILLING_INTERNAL_API_KEY=

# Optional — AI draft commentary on exports and POST /api/v1/commentary/generate
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TEMPERATURE=0.2
# OPENAI_TIMEOUT_SECONDS=60
