# Copy to frontend/.env.local
# Browser fetch targets (most dashboards call the backend directly).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8001
# Next.js server proxy (Management P&L + Workforce) — must match the running uvicorn port.
SFI_BACKEND_URL=http://127.0.0.1:8001
# Optional — path to Claude board HTML for copy:board (defaults to Downloads export)
# SMPL_BOARD_HTML_SRC=C:\Users\mattj\Downloads\SMPL_Board_Platform_May2026 (5).html

# Optional — May 2026 board export files for /board MD&A buttons (defaults to OneDrive)
# SMPL_BOARD_PPTX_SRC=C:\Users\mattj\OneDrive\SMPL_Board_Review_May2026.pptx
# SMPL_MDA_XLSX_SRC=C:\Users\mattj\OneDrive\SMPL_MDA_Package_May2026.xlsx
# Public scheduling link (Calendly, Cal.com, Google Calendar appointment page, etc.)
# NEXT_PUBLIC_SCHEDULING_URL=https://calendar.app.google/R8yf5HpyPwAitKq16

# HubSpot private app token — server-side only (never NEXT_PUBLIC_*)
# HUBSPOT_PRIVATE_APP_TOKEN=pat-...
# Optional overrides:
# HUBSPOT_PIPELINE_NAME=SMPL Inbound Sales
# HUBSPOT_PIPELINE_ID=
# HUBSPOT_DEAL_STAGE_ID=
# HUBSPOT_TOKEN_FILE=C:\Users\mattj\OneDrive\Documents\HubSpot Token.txt

# Stripe billing (server-side secrets — never NEXT_PUBLIC_ except publishable key)
# Local: reads sk_/pk_/whsec_ from this file if env vars are unset (same pattern as HubSpot)
# STRIPE_TOKEN_FILE=C:\Users\mattj\OneDrive\Documents\Stripe Token.txt
# APP_BASE_URL=http://localhost:3002
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_STARTER_MONTHLY_PRICE_ID=
# STRIPE_STARTER_ANNUAL_PRICE_ID=
# Optional post-contract Stripe prices (not used on public /pricing page)
# STRIPE_PROFESSIONAL_MONTHLY_PRICE_ID=
# STRIPE_PROFESSIONAL_ANNUAL_PRICE_ID=
# STRIPE_GROWTH_MONTHLY_PRICE_ID=
# STRIPE_GROWTH_ANNUAL_PRICE_ID=
# BILLING_INTERNAL_API_KEY=

# Auth.js customer login (see docs/CUSTOMER_ACCESS.md and docs/RESEND_EMAIL_SETUP.md)
# AUTH_SECRET=
# AUTH_URL=http://localhost:3002
# AUTH_DATABASE_URL=postgresql://sfi:sfi_dev_password@localhost:5432/sfi
# Resend (recommended) — API key in file or env; see scripts/setup-resend-email.ps1
# RESEND_TOKEN_FILE=C:\Users\mattj\OneDrive\Documents\Resend Token.txt
# AUTH_RESEND_KEY=re_...
# EMAIL_FROM=onboarding@resend.dev
# Optional SMTP fallback:
# EMAIL_SERVER=smtp://resend:re_YOUR_KEY@smtp.resend.com:587
