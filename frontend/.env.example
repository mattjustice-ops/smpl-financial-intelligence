# Copy to frontend/.env.local
# Browser fetch targets (most dashboards call the backend directly).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8001
# Next.js server proxy (Management P&L + Workforce) — must match the running uvicorn port.
SFI_BACKEND_URL=http://127.0.0.1:8001
